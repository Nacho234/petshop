# Contraseña del panel de administración (/admin).
# Debe empezar con VITE_ para que Vite la exponga al cliente.
# Copiá este archivo a .env.local y poné tu token/contraseña real.
# NOTA: al ser una app 100% front, este valor queda incrustado en el build:
# es una tranca liviana, no un secreto real.
VITE_ADMIN_PASSWORD=tu-token-aca
